# Copy to .env.local — never commit .env.local

# Local development GraphQL endpoint (Apollo Server at project root).
VITE_GRAPHQL_URL=http://localhost:4000

# Production Railway API URL — set this in your Vercel environment variables.
# When set, it takes priority over VITE_GRAPHQL_URL.
# Example: https://narrative-tracker-server-production.up.railway.app
VITE_API_URL=
